{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "nodeVersion": "18.x",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x",
      "memory": 512,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
