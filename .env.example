# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your-key...

# OpenAI Configuration
OPENAI_API_KEY=sk-...your-key...

# Email Service Configuration
# Choose ONE: resend, sendgrid, or mailgun
EMAIL_SERVICE=resend

# For Resend (https://resend.com)
# RESEND_API_KEY=re_...your-key...

# For SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=SG....your-key...

# For Mailgun (https://mailgun.com)
# MAILGUN_API_KEY=...your-key...
# MAILGUN_DOMAIN=mg.yourdomain.com

# Admin Email (where candidate notifications are sent)
ADMIN_EMAIL=your-email@company.com

# Vercel Environment
VITE_API_URL=/api
